# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/signal_agent

# ── Hedera operator wallet ────────────────────────────────────────────────────
# The account that pays for (and signs) the HBAR signal transactions.
# Must be an ECDSA secp256k1 key (accounts created via HashPack, Blade, or
# the Hedera developer portal use this key type by default).
SIGNAL_OPERATOR_ACCOUNT_ID=0.0.XXXXXXX
SIGNAL_OPERATOR_PRIVATE_KEY=302e...  # DER-encoded ECDSA hex private key

# ── Network ───────────────────────────────────────────────────────────────────
SIGNAL_AGENT_NETWORK=mainnet          # or "testnet"
HEDERA_MIRROR_BASE_URL=https://mainnet.mirrornode.hedera.com/api/v1

# ── Policy knobs ─────────────────────────────────────────────────────────────
SIGNAL_AGENT_ENABLED=false            # Set to "true" to enable live sends
SIGNAL_DRY_RUN_DEFAULT=true           # "false" to send real transactions
SIGNAL_REQUIRE_HUMAN_APPROVAL=true    # Require admin approval before each send
SIGNAL_AMOUNT_TINYBARS=1              # Amount per signal (1 tinybar = 0.00000001 ℏ)
SIGNAL_MAX_BATCH_SIZE=50              # Max groups in a single batch send
SIGNAL_MAX_OWNER_DAILY=5             # Max signals per NFT owner per day
SIGNAL_MAX_GLOBAL_DAILY=200          # Max total signals per day
SIGNAL_ESTIMATED_CRYPTO_TRANSFER_FEE_USD=0.0001

# ── Admin auth ────────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-before-production
# Set ADMIN_BYPASS=true for local development (skips JWT check)
ADMIN_BYPASS=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
